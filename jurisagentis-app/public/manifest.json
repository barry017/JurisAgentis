  "screenshots": [
    {
      "src": "/screenshots/desktop-dashboard.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Dashboard view showing case overview and analytics"
    },
    {
      "src": "/screenshots/mobile-cases.png",
      "sizes": "375x667",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Mobile case management interface"
    },
    {
      "src": "/screenshots/mobile-time-tracking.png",
      "sizes": "375x667",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Mobile time tracking and billing"
    }
  ],
  "shortcuts": [
    {
      "name": "New Case",
      "short_name": "New Case",
      "description": "Create a new legal case",
      "url": "/cases/new",
      "icons": [
        {
          "src": "/icons/shortcut-new-case.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Time Tracker",
      "short_name": "Timer",
      "description": "Start time tracking",
      "url": "/time-tracking",
      "icons": [
        {
          "src": "/icons/shortcut-timer.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Calendar",
      "short_name": "Calendar",
      "description": "View upcoming appointments",
      "url": "/calendar",
      "icons": [
        {
          "src": "/icons/shortcut-calendar.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Scan Document",
      "short_name": "Scan",
      "description": "Scan and upload documents",
      "url": "/documents/scan",
      "icons": [
        {
          "src": "/icons/shortcut-scan.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "web+jurisagentis",
      "url": "/protocol-handler?protocol=%s"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": [
            "image/*",
            "application/pdf",
            "application/msword",
            "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
            "text/plain"
          ]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "/file-handler",
      "accept": {
        "application/pdf": [".pdf"],
        "application/msword": [".doc"],
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document": [".docx"],
        "text/plain": [".txt"]
      },
      "icons": [
        {
          "src": "/icons/file-handler.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.jurisagentis.mobile",
      "id": "com.jurisagentis.mobile"
    },
    {
      "platform": "itunes",
      "url": "https://apps.apple.com/app/jurisagentis/id123456789",
      "id": "123456789"
    }
  ]
}